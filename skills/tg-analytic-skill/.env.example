# Telegram API credentials — get from https://my.telegram.org/apps
# Copy this file to `.tg-analytic/.env` at your project root and fill in the values.
TG_API_ID=
TG_API_HASH=
TG_PHONE=+

# Optional — only needed to run inside a sandbox that allowlists DOMAINS, not IPs.
# Telethon dials Telegram's data centers by fixed IP; a wildcard-DNS suffix makes
# it dial `<dc-ip>.<suffix>` instead (e.g. 149.154.167.51.nip.io), a hostname that
# resolves back to the same IP. Allowlist that one domain in the sandbox.
# Leave unset for normal (raw-IP) connections.
# TG_DC_DNS_SUFFIX=nip.io
